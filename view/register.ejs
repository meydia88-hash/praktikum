<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Akun — API Express</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            padding: 2rem 1rem;
            position: relative;
            overflow-x: hidden;
        }

        /* ===== LANGIT ===== */
        .sky {
            position: fixed; inset: 0;
            background: linear-gradient(
                180deg,
                #0a1628 0%,
                #0d2347 15%,
                #0e3a6e 35%,
                #1565c0 55%,
                #42a5f5 75%,
                #87ceeb 88%,
                #e0f4ff 100%
            );
            z-index: 0;
        }

        .stars { position: fixed; inset: 0; z-index: 1; pointer-events: none; }
        .star {
            position: absolute; background: #fff; border-radius: 50%;
            animation: twinkle var(--dur) ease-in-out infinite; opacity: 0;
        }
        @keyframes twinkle {
            0%,100% { opacity:0; transform:scale(0.8); }
            50%      { opacity:var(--op); transform:scale(1); }
        }

        .clouds { position: fixed; inset: 0; z-index: 2; pointer-events: none; overflow: hidden; }
        .cloud {
            position: absolute; background: rgba(255,255,255,0.92);
            border-radius: 50px; filter: blur(1px);
            animation: floatCloud var(--spd) linear infinite;
        }
        .cloud::before, .cloud::after {
            content: ''; position: absolute;
            background: rgba(255,255,255,0.92); border-radius: 50%;
        }
        .cloud-1 { width:140px; height:40px; top:62%; --spd:35s; left:-160px; opacity:0.85; }
        .cloud-1::before { width:70px; height:55px; top:-30px; left:18px; }
        .cloud-1::after  { width:55px; height:45px; top:-22px; left:60px; }
        .cloud-2 { width:100px; height:30px; top:68%; --spd:50s; left:-120px; opacity:0.7; animation-delay:-18s; }
        .cloud-2::before { width:50px; height:40px; top:-22px; left:12px; }
        .cloud-2::after  { width:40px; height:33px; top:-16px; left:44px; }
        .cloud-3 { width:180px; height:48px; top:72%; --spd:42s; left:-200px; opacity:0.8; animation-delay:-8s; }
        .cloud-3::before { width:88px; height:68px; top:-38px; left:22px; }
        .cloud-3::after  { width:70px; height:55px; top:-28px; left:80px; }
        .cloud-4 { width:120px; height:34px; top:78%; --spd:60s; left:-140px; opacity:0.6; animation-delay:-30s; }
        .cloud-4::before { width:58px; height:46px; top:-26px; left:14px; }
        .cloud-4::after  { width:48px; height:38px; top:-19px; left:52px; }
        @keyframes floatCloud {
            from { transform: translateX(0); }
            to   { transform: translateX(calc(100vw + 300px)); }
        }

        .sunlight {
            position: fixed; bottom: -60px; left: 50%; transform: translateX(-50%);
            width: 600px; height: 300px;
            background: radial-gradient(ellipse at center bottom,
                rgba(255,200,80,0.22) 0%, rgba(255,160,50,0.10) 40%, transparent 70%);
            z-index: 2; pointer-events: none;
        }

        /* ===== KONTEN ===== */
        .auth-logo {
            position: relative; z-index: 10;
            text-align: center; margin-bottom: 1.5rem;
        }
        .auth-logo .icon-wrap {
            width: 74px; height: 74px;
            background: rgba(255,255,255,0.18);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 0.75rem;
            border: 1.5px solid rgba(255,255,255,0.4);
            backdrop-filter: blur(8px);
            box-shadow: 0 0 24px rgba(135,206,235,0.3);
        }
        .auth-logo .icon-wrap i { font-size: 1.9rem; color: #fff; }
        .auth-logo h4 {
            color: #fff; font-weight: 700; font-size: 1.5rem;
            text-shadow: 0 2px 12px rgba(0,0,0,0.3); margin-bottom: 0.2rem;
        }
        .auth-logo p {
            color: rgba(255,255,255,0.75); font-size: 0.85rem;
            text-shadow: 0 1px 6px rgba(0,0,0,0.2);
        }

        .auth-card {
            position: relative; z-index: 10;
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.7);
            border-radius: 20px;
            padding: 2.25rem 2rem;
            box-shadow: 0 8px 32px rgba(14,58,110,0.18), 0 1px 0 rgba(255,255,255,0.6) inset;
            width: 100%; max-width: 440px;
            animation: cardDrop 0.5s cubic-bezier(0.22,1,0.36,1);
        }
        @keyframes cardDrop {
            from { opacity:0; transform:translateY(24px) scale(0.97); }
            to   { opacity:1; transform:translateY(0) scale(1); }
        }

        .step-badge {
            display: inline-flex; align-items: center; gap: 0.35rem;
            background: #e3f2fd; color: #1565c0;
            font-size: 0.72rem; font-weight: 700;
            padding: 0.25rem 0.8rem; border-radius: 20px; margin-bottom: 0.9rem;
        }

        .auth-card h5 { font-weight: 700; color: #0d2347; font-size: 1.2rem; margin-bottom: 0.2rem; }
        .auth-card .subtitle { color: #6c7a8a; font-size: 0.84rem; margin-bottom: 1.5rem; }

        .field-label {
            display: block; font-size: 0.74rem; font-weight: 700;
            color: #3a5068; text-transform: uppercase;
            letter-spacing: 0.5px; margin-bottom: 0.4rem;
        }

        .field-wrap { position: relative; margin-bottom: 1.1rem; }
        .field-icon {
            position: absolute; left: 13px; top: 50%;
            transform: translateY(-50%);
            color: #90b4ce; font-size: 0.88rem;
            pointer-events: none; z-index: 2;
        }
        .field-wrap input {
            width: 100%; height: 46px; padding: 0 42px;
            border: 1.5px solid #c8dff0; border-radius: 10px;
            font-size: 0.9rem; color: #1a3c5e;
            background: rgba(255,255,255,0.85);
            outline: none; transition: border-color 0.2s, box-shadow 0.2s;
        }
        .field-wrap input:focus {
            border-color: #42a5f5;
            box-shadow: 0 0 0 3px rgba(66,165,245,0.15);
            background: #fff;
        }
        .field-wrap input::placeholder { color: #b0c4d8; }
        .toggle-eye {
            position: absolute; right: 13px; top: 50%;
            transform: translateY(-50%);
            color: #90b4ce; cursor: pointer;
            font-size: 0.88rem; z-index: 2; transition: color 0.2s;
        }
        .toggle-eye:hover { color: #1565c0; }

        .info-box {
            display: flex; align-items: flex-start; gap: 0.5rem;
            background: rgba(227,242,253,0.7);
            border: 1px solid #bee3f8;
            border-radius: 10px;
            padding: 0.7rem 1rem;
            font-size: 0.82rem; color: #2c5282;
            margin-bottom: 1.1rem;
        }
        .info-box i { color: #1565c0; margin-top: 2px; flex-shrink: 0; }

        .btn-register {
            display: block; width: 100%; height: 48px;
            background: linear-gradient(135deg, #1565c0 0%, #42a5f5 100%);
            border: none; border-radius: 10px;
            color: #fff; font-weight: 700; font-size: 0.9rem;
            cursor: pointer; transition: all 0.25s;
            box-shadow: 0 4px 16px rgba(21,101,192,0.4);
            margin-top: 0.4rem;
        }
        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(21,101,192,0.5);
        }

        .divider { text-align: center; position: relative; margin: 1.4rem 0; }
        .divider::before {
            content: ''; position: absolute; top: 50%; left: 0; right: 0;
            height: 1px; background: #d8eaf7;
        }
        .divider span {
            background: rgba(255,255,255,0.92); padding: 0 1rem;
            position: relative; color: #a0b8cc; font-size: 0.78rem;
        }

        .login-link { text-align: center; font-size: 0.875rem; color: #6c8ea4; }
        .login-link a { color: #1565c0; font-weight: 700; text-decoration: none; }
        .login-link a:hover { text-decoration: underline; }

        .alert-error {
            display: flex; align-items: center; gap: 0.5rem;
            background: #fff5f5; color: #c53030;
            border: 1px solid #fed7d7;
            border-radius: 10px; padding: 0.7rem 1rem;
            font-size: 0.84rem; margin-bottom: 1rem;
        }

        /* ===== QR SECTION ===== */
        .qr-section {
            background: rgba(240,255,244,0.9);
            border: 2px solid #68d391;
            border-radius: 16px;
            padding: 1.75rem 1.5rem;
            text-align: center;
            animation: fadeInUp 0.4s ease;
        }
        @keyframes fadeInUp {
            from { opacity:0; transform:translateY(12px); }
            to   { opacity:1; transform:translateY(0); }
        }

        .success-badge {
            display: inline-flex; align-items: center; gap: 0.4rem;
            background: linear-gradient(135deg, #38a169, #48bb78);
            color: #fff; font-size: 0.78rem; font-weight: 700;
            padding: 0.3rem 0.9rem; border-radius: 20px; margin-bottom: 0.9rem;
            box-shadow: 0 3px 10px rgba(56,161,105,0.3);
        }

        .qr-section h6 { font-weight: 700; color: #1a4731; font-size: 1rem; margin-bottom: 0.2rem; }
        .qr-section .qr-sub { color: #2f7a50; font-size: 0.82rem; margin-bottom: 1.25rem; }

        .qr-section img {
            width: 175px; height: 175px;
            border-radius: 12px;
            border: 3px solid #fff;
            box-shadow: 0 6px 24px rgba(0,0,0,0.12);
            display: block; margin: 0 auto 1rem;
        }

        .manual-label { font-size: 0.78rem; color: #6c8ea4; margin-bottom: 0.4rem; }

        .secret-code {
            background: rgba(255,255,255,0.9);
            border: 1.5px dashed #68d391;
            border-radius: 10px;
            padding: 0.55rem 1rem;
            font-family: 'Courier New', monospace;
            font-size: 0.85rem; font-weight: 700;
            color: #0d2347; letter-spacing: 2px;
            word-break: break-all; margin-bottom: 1.1rem;
        }

        .steps-list {
            text-align: left; background: rgba(255,255,255,0.85);
            border-radius: 10px; padding: 0.75rem 1rem;
            margin-bottom: 1.25rem; list-style: none;
        }
        .steps-list li {
            font-size: 0.82rem; color: #2f6b4a;
            margin-bottom: 0.35rem;
            display: flex; align-items: flex-start; gap: 0.5rem;
        }
        .steps-list li:last-child { margin-bottom: 0; }
        .steps-list li i { color: #48bb78; margin-top: 2px; flex-shrink: 0; }

        .btn-go-login {
            display: block; width: 100%; height: 44px;
            background: linear-gradient(135deg, #1565c0 0%, #42a5f5 100%);
            border: none; border-radius: 10px;
            color: #fff; font-weight: 700; font-size: 0.875rem;
            cursor: pointer; transition: all 0.25s;
            text-decoration: none; line-height: 44px;
            box-shadow: 0 4px 16px rgba(21,101,192,0.35);
        }
        .btn-go-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(21,101,192,0.5);
            color: #fff; text-decoration: none;
        }

        .footer-note {
            position: relative; z-index: 10;
            color: rgba(255,255,255,0.5); font-size: 0.75rem;
            text-align: center; margin-top: 1.25rem;
            text-shadow: 0 1px 4px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body>

    <div class="sky"></div>
    <div class="stars" id="stars"></div>
    <div class="clouds">
        <div class="cloud cloud-1"></div>
        <div class="cloud cloud-2"></div>
        <div class="cloud cloud-3"></div>
        <div class="cloud cloud-4"></div>
    </div>
    <div class="sunlight"></div>

    <!-- Logo -->
    <div class="auth-logo">
        <div class="icon-wrap">
            <i class="fas fa-user-plus"></i>
        </div>
        <h4>API Express</h4>
        <p>Buat akun baru dengan keamanan 2FA</p>
    </div>

    <!-- Card -->
    <div class="auth-card">

        <% if (!qrCode) { %>

        <div class="step-badge">
            <i class="fas fa-pen"></i> Formulir Pendaftaran
        </div>
        <h5>Daftar Akun Baru</h5>
        <p class="subtitle">Isi data di bawah untuk membuat akun</p>

        <% if (error) { %>
        <div class="alert-error">
            <i class="fas fa-circle-exclamation"></i> <%= error %>
        </div>
        <% } %>

        <form method="POST" action="/register">

            <label class="field-label">Username</label>
            <div class="field-wrap">
                <i class="fas fa-user field-icon"></i>
                <input type="text" name="username"
                    placeholder="Pilih username"
                    required autocomplete="username">
            </div>

            <label class="field-label">Password</label>
            <div class="field-wrap">
                <i class="fas fa-lock field-icon"></i>
                <input type="password" name="password" id="passwordInput"
                    placeholder="Minimal 8 karakter"
                    required minlength="8" autocomplete="new-password">
                <i class="fas fa-eye toggle-eye" id="eyeIcon" onclick="togglePassword()"></i>
            </div>

            <div class="info-box">
                <i class="fas fa-circle-info"></i>
                Setelah daftar, Anda akan mendapat <strong>&nbsp;QR Code&nbsp;</strong> untuk discan di Google Authenticator.
            </div>

            <button type="submit" class="btn-register">
                <i class="fas fa-user-plus"></i>&nbsp; Buat Akun
            </button>

        </form>

        <div class="divider"><span>sudah punya akun?</span></div>
        <div class="login-link">
            <a href="/login"><i class="fas fa-arrow-left"></i> Kembali ke halaman login</a>
        </div>

        <% } else { %>

        <div class="step-badge">
            <i class="fas fa-check-circle"></i> Akun Berhasil Dibuat
        </div>
        <h5>Satu Langkah Lagi!</h5>
        <p class="subtitle">Scan QR Code ini dengan Google Authenticator</p>

        <div class="qr-section">
            <div class="success-badge">
                <i class="fas fa-qrcode"></i> Scan QR Code
            </div>
            <h6>Hubungkan Google Authenticator</h6>
            <p class="qr-sub">Buka Google Authenticator lalu scan QR di bawah ini</p>

            <img src="<%= qrCode %>" alt="QR Code Google Authenticator">

            <p class="manual-label">Tidak bisa scan? Masukkan kode ini secara manual:</p>
            <div class="secret-code"><%= secret %></div>

            <ul class="steps-list">
                <li><i class="fas fa-check-circle"></i> Buka <strong>Google Authenticator</strong> di HP Anda</li>
                <li><i class="fas fa-check-circle"></i> Tap tombol <strong>+</strong> lalu pilih <em>Scan QR Code</em></li>
                <li><i class="fas fa-check-circle"></i> Arahkan kamera ke QR Code di atas</li>
                <li><i class="fas fa-check-circle"></i> Kode 6 digit akan muncul otomatis — siap digunakan!</li>
            </ul>

            <a href="/login" class="btn-go-login">
                <i class="fas fa-arrow-right-to-bracket"></i>&nbsp; Lanjut ke Halaman Login
            </a>
        </div>

        <% } %>

    </div>


<script>
(function() {
    const container = document.getElementById('stars');
    for (let i = 0; i < 120; i++) {
        const s = document.createElement('div');
        s.className = 'star';
        const size = Math.random() * 2.5 + 0.5;
        s.style.cssText = `
            width:${size}px; height:${size}px;
            top:${Math.random() * 55}%;
            left:${Math.random() * 100}%;
            --dur:${Math.random() * 3 + 2}s;
            --op:${Math.random() * 0.7 + 0.3};
            animation-delay:${Math.random() * 4}s;
        `;
        container.appendChild(s);
    }
})();

function togglePassword() {
    const input = document.getElementById('passwordInput');
    const icon  = document.getElementById('eyeIcon');
    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
    }
}
</script>

</body>
</html>